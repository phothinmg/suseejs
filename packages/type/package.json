{
	"name": "@suseejs/type",
	"version": "0.0.2",
	"description": "Type Def for SuseeJs",
	"main": "dist/index.cjs",
	"types": "dist/index.d.cts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsx build.ts",
		"lint": "biome check src --write",
		"fmt": "biome format --write"
	},
	"author": {
		"name": "Pho Thin Mg",
		"email": "phothinmg@disroot.org",
		"url": "https://phothinmg.github.io/"
	},
	"keywords": [
		"suseejs"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/phothinmg/suseejs.git",
		"directory": "packages/type"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"package.json"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"@suseejs/compiler": "file:../compiler",
		"@suseejs/files": "file:../files",
		"@suseejs/tsoptions": "file:../tsoptions",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0"
	},
	"dependencies": {
		"typescript": "^6.0.3"
	},
	"type": "module"
}
