{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./dist",
		"target": "esnext",
		"types": ["node"],
		"sourceMap": true,
		"declaration": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": ["src/**/*", "build.ts"]
}
