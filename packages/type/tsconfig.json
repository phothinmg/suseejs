{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "esnext",
		"types": [],
		"sourceMap": true,
		"declaration": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": ["src/**/*"]
}
