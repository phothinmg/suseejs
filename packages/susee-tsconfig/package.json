{
  "name": "susee-tsconfig",
  "version": "0.0.6",
  "description": "Get TypeScript compiler options and tsconfig file",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "susee-tcolor": "file:../susee-tcolor",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/phothinmg/suseejs.git"
  },
  "bugs": {
    "url": "https://github.com/phothinmg/suseejs/issues"
  },
  "homepage": "https://github.com/phothinmg/suseejs/blob/main/packages/susee-tsconfig/README.md",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
