{
	"name": "@suseejs/compiler",
	"version": "0.0.1",
	"description": "TypeScript compiler",
	"main": "dist/commonjs/index.js",
	"types": "dist/commonjs/index.d.ts",
	"module": "dist/index.js",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/commonjs/index.d.ts",
				"default": "./dist/commonjs/index.js"
			}
		}
	},
	"scripts": {
		"commonjs": "tsc -p ts-commonjs.json",
		"esm": "tsc -p ts-esm.json",
		"build": "npm run commonjs && npm run esm",
		"test": "tsx --test",
		"lcov": "tsx --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=tests/lcov.info",
		"lint": "biome check src --write",
		"fmt": "biome format --write"
	},
	"author": {
		"name": "Pho Thin Mg",
		"email": "phothinmg@disroot.org",
		"url": "https://phothinmg.github.io/"
	},
	"keywords": [
		"suseejs"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/phothinmg/suseejs.git",
		"directory": "packages/tsoptions"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"package.json"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"typescript": "^6.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0"
	},
	"type": "module"
}
