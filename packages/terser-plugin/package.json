{
	"name": "@suseejs/terser-plugin",
	"version": "0.0.2",
	"description": "A Susee plugin that minifies JavaScript code using the Terser library.",
	"type": "module",
	"main": "dist/index.cjs",
	"types": "dist/index.d.cts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "node build.mjs",
		"lint": "biome check src --write",
		"fmt": "biome format --write"
	},
	"author": {
		"name": "Pho Thin Mg",
		"email": "phothinmg@disroot.org",
		"url": "https://phothinmg.github.io/"
	},
	"keywords": [
		"suseejs"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/phothinmg/suseejs.git",
		"directory": "packages/banner-text-plugin"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"package.json"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@suseejs/compiler": "file:../compiler",
		"@suseejs/type": "file:../type",
		"@types/node": "^25.6.0"
	},
	"dependencies": {
		"terser": "^5.46.1"
	}
}
