{
  "name": "suseejs",
  "version": "0.0.2",
  "description": "Susee Js Monorepo",
  "type": "module",
  "scripts": {
    "hooks:install": "bash scripts/install-hooks.sh",
    "build": "npm run build --workspaces --if-present",
    "publish:ws": "npm publish --workspaces --if-present",
    "release:ws": "node release/index.mjs",
    "v:patch": "npm version patch --no-git-tag-version && npm version patch --workspaces",
    "v:minor": "npm version minor --no-git-tag-version && npm version minor --workspaces",
    "v:major": "npm version major --no-git-tag-version && npm version major --workspaces",
    "commit": "bash scripts/commit.sh",
    "test": "npm run test --workspaces --if-present",
    "coverage": "bash scripts/coverage.sh"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "workspaces": [
    "packages/compiler",
    "packages/tsoptions",
    "packages/files",
    "packages/color",
    "packages/type",
    "packages/utilities",
    "packages/graph",
    "packages/bundler",
    "packages/commonjs-plugin",
    "packages/terser-plugin",
    "packages/banner-text-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phothinmg/suseejs.git"
  },
  "devDependencies": {
    "@suseejs/color": "^0.0.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
