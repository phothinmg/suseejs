{
  "name": "suseejs",
  "version": "0.0.1",
  "description": "Susee Js Monorepo",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fmt": "npm run fmt --workspaces --if-present",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "keywords": [
    "suseejs"
  ],
