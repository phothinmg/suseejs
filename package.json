{
  "name": "suseejs",
  "version": "0.1.0",
  "description": "Susee Js Monorepo",
  "type": "module",
  "workspaces": [
    "packages/susee-types",
    "packages/susee-tcolor",
    "packages/susee-utils",
    "packages/susee-transform",
    "packages/susee-tsconfig",
    "packages/susee-plugin-banner-text",
    "packages/susee-plugin-terser",
    "packages/susee-plugin-commonjs",
    "packages/susee-anonymous",
    "packages/susee-duplicate",
    "packages/susee-remove",
    "packages/susee-export-default"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "fmt": "biome format --write",
    "build": "npm run build --workspaces --if-present",
    "publish:ws": "npm publish --workspaces --if-present",
    "release:ws": "node scripts/release.mjs",
    "v:patch": "npm version patch --no-git-tag-version && npm version patch --workspaces",
    "v:minor": "npm version minor --no-git-tag-version && npm version minor --workspaces",
    "v:major": "npm version major --no-git-tag-version && npm version major --workspaces",
    "commit:release": "tsx scripts/release-commit.ts",
    "release:patch": "npm run v:patch && npm run commit:release",
    "release:minor": "npm run v:minor && npm run commit:release",
    "release:major": "npm run v:major && npm run commit:release",
    "test": "npm run test --workspaces --if-present",
    "hooks:install": "bash scripts/install-hooks.sh",
    "commit": "tsx scripts/susee-commit.ts"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/phothinmg/suseejs.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
