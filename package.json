  "workspaces": [
    "packages/utilities",
    "packages/color",
    "packages/type"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phothinmg/suseejs.git"
  },
  "devDependencies": {
    "@suseejs/color": "^0.0.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
