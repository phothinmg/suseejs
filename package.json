{
  "name": "suseejs",
  "version": "0.0.1",
  "description": "Susee Js Monorepo",
  "type": "module",
  "workspaces": [
    "packages/susee-types",
    "packages/susee-tcolor",
    "packages/susee-utils"
  ],
  "scripts": {
    "lint": "biome check --write",
    "fmt": "biome format --write",
    "build": "npm run build --workspaces --if-present",
    "publish:ws": "npm publish --workspaces --if-present",
    "release:ws": "node scripts/release.mjs",
    "v:patch": "npm version patch --workspaces",
    "v:minor": "npm version minor --workspaces",
    "v:major": "npm version major --workspaces"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/phothinmg/suseejs.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
